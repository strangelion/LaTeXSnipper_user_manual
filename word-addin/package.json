{
  "name": "latexsnipper-office-addin",
  "version": "1.0.0",
  "description": "LaTeXSnipper Office Add-in – LaTeX/Typst formula editor for Word & PowerPoint",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "start": "office-addin-debugging start manifest-dev.xml",
    "stop": "office-addin-debugging stop manifest-dev.xml",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.409",
    "@types/office-runtime": "^1.0.35",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "dependencies": {
    "pandoc-wasm": "^0.0.2-dev.2"
  }
}
