{
  "name": "latexsnipper-manual",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "onnxruntime-web": "^1.26.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "wrangler": "^3.100.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:manual",
    "build:manual": "node scripts/copy-assets.cjs",
